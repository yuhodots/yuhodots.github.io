sertion</a></p>\n<ul>\n<li>\n<ul>\n<li><a href=\"#bootstrapping-counterfactual-dataset\">Bootstrapping Counterfactual Dataset</a></li>\n<li><a href=\"#diffusion-model-training\">Diffusion Model Training</a></li>\n</ul>\n</li>\n</ul>\n</li>\n<li>\n<p><a href=\"#experiments\">Experiments</a></p>\n</li>\n</ul>","frontmatter":{"path":"/deeplearning/25-06-01/","title":"Paper Review: ObjectDrop (ECCV 2024)","category":"Deep Learning","date":"2025-06-01"}}},"pageContext":{"postPath":"/deeplearning/25-06-01/","language":"eng","langRegex":"/contents/eng/"}},"staticQueryHashes":["2145088972","256249292","63159454"],"slicesMap":{}}