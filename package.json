  "scripts": {
    "build": "node scripts/check-node-version.js && gatsby build",
    "develop": "gatsby develop",
    "lint": "node_modules/.bin/eslint *.js src/**/*.js --fix",
    "format": "prettier --write \"**/*.{js,jsx,json,md}\" && npm run lint",
    "start": "npm run develop",
    "serve": "gatsby serve",
    "clean": "node scripts/check-node-version.js && gatsby clean",
    "test": "echo \"Write tests! -> https://gatsbyjs.dev/unit-testing\" && exit 1",
    "deploy": "npm run clean && npm run build && cd public && rm *.map && cd .. && gh-pages -b master -d public"
  },
  "repository": {
    "type": "git",
